{
  "entities": {
    "Trade": {
      "title": "Trade",
      "description": "A trade offer created by a player.",
      "type": "object",
      "properties": {
        "code": { "type": "string", "description": "6-digit unique trade code." },
        "senderId": { "type": "string", "description": "UID of the player offering the card." },
        "senderEmail": { "type": "string", "description": "Email of the player offering the card." },
        "pokemonId": { "type": "number", "description": "ID of the Pokemon card being traded." },
        "status": { "type": "string", "enum": ["pending", "completed", "cancelled"], "description": "Current status of the trade." },
        "createdAt": { "type": "string", "format": "date-time", "description": "When the trade was created." },
        "receiverId": { "type": "string", "description": "UID of the player who accepted the trade." }
      },
      "required": ["code", "senderId", "pokemonId", "status", "createdAt"]
    },
    "User": {
      "title": "User",
      "description": "User profile and collection data.",
      "type": "object",
      "properties": {
        "email": { "type": "string" },
        "lastLogin": { "type": "string", "format": "date-time" },
        "coins": { "type": "number" },
        "lastHealTime": { "type": "number" },
        "badges": { "type": "array", "items": { "type": "string" } },
        "inventory": { "type": "object" },
        "lastDailyReward": { "type": "number" },
        "currentRegion": { "type": "number" },
        "unlockedRegions": { "type": "array", "items": { "type": "number" } },
        "isInfiniteCoins": { "type": "boolean" },
        "attackBoosts": { "type": "object" },
        "defenseBoosts": { "type": "object" },
        "transferUses": { "type": "object" },
        "hpMap": { "type": "object" },
        "cards": { "type": "object", "description": "Map of card ID to count" }
      }
    }
  },
  "firestore": {
    "/trades/{tradeId}": {
      "schema": "Trade",
      "description": "Active and past trade offers."
    },
    "/users/{userId}": {
      "schema": "User",
      "description": "User metadata."
    }
  }
}
